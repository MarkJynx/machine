@startuml

skinparam linetype ortho
hide circle
hide empty members

entity Rule {
    * Name <<PK>>
    * OrderPriority
    * Period
    * Weekdays
}

entity RuleInstance {
    * ID <<PK>>
    * RuleName <<FK>>
    * DayID <<FK>>
    * Done
    * OrderPriority
}

entity Day {
    * ID <<PK>>
    * Notes
}

Rule ||--o{ RuleInstance
Day ||--o{ RuleInstance

@enduml
