@startuml

skinparam linetype ortho
hide circle
hide empty members

entity Rule {
    * Name <<PK>>
    * RuleTier
    * Description
    * Motivation
    * OrderPriority
    * Period
    * Weekdays
}

entity RuleInstance {
    * ID <<PK>>
    * RuleName <<FK>>
    * RuleSchedule <<FK>>
    * DayID <<FK>>
    * Done
    * OrderPriority
    * Notes
}

entity Day {
    * ID <<PK>>
    * Notes
}

Rule ||--o{ RuleInstance
Day ||--o{ RuleInstance

@enduml
